    <manualTask id="Id_f388fc09-9e28-4268-8e39-03ea8c21a8d7" name="Realizar rectificación de medidas">
      <documentation>&lt;p style="text-align:left;text-indent:0pt;margin:0pt 0pt 0pt 0pt;"&gt;&lt;span style="color:#000000;background-color:transparent;font-family:Calibri;font-size:11pt;font-weight:normal;font-style:normal;"&gt;Se mide el ancho, alto y el alojamiento de la puerta en distintos puntos para detectar deniveles. Se toman fotos del entorno para prever problemas de instalaci&amp;oacute;n.&lt;/span&gt;&lt;/p&gt;</documentation>
      <extensionElements>
        <bizagi:BizagiExtensions xmlns:bizagi="http://www.bizagi.com/bpmn20">
