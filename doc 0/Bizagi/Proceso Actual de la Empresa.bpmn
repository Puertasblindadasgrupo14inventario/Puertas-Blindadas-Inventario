    <manualTask id="Id_b8260326-31b3-4a28-8768-2d296989c3b5" name="Recibir orden de entrega">
      <documentation>&lt;p style="text-align:left;text-indent:0pt;margin:0pt 0pt 0pt 0pt;"&gt;&lt;span style="color:#000000;background-color:transparent;font-family:Calibri;font-size:11pt;font-weight:normal;font-style:normal;"&gt;Antes de ir a instalar, el t&amp;eacute;cnico recoge la ficha f&amp;iacute;sica que contiene las especificaciones finales y observaciones para el cliente.&lt;/span&gt;&lt;/p&gt;</documentation>
