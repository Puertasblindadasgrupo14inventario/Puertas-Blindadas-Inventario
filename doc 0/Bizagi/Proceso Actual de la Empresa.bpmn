    <manualTask id="Id_c264fa12-70a1-46f0-94f9-a3de97aeaddd" name="Llenar la nota de venta">
      <documentation>&lt;p style="text-align:left;text-indent:0pt;margin:0pt 0pt 0pt 0pt;"&gt;&lt;span style="color:#000000;background-color:transparent;font-family:Calibri;font-size:11pt;font-weight:normal;font-style:normal;"&gt;En una hoja se anotan todos los datos t&amp;eacute;cnicos levantados (medidas descontando holguras, sentido de apertura, material del marco, etc.) y se le pide la firma al cliente.&lt;/span&gt;&lt;/p&gt;&lt;p style="text-align:left;text-indent:0pt;margin:0pt 0pt 0pt 0pt;"&gt;&lt;span style="color:#000000;background-color:transparent;font-family:Calibri;font-size:11pt;font-weight:normal;font-style:normal;"&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;</documentation>
